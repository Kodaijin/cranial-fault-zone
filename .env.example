# Cranial Fault Zone — environment variables
# Copy to .env and fill in real values. NEVER commit real keys.

# OpenWeatherMap and Ambee keys are NO LONGER REQUIRED.
# Weather and environmental data now come from Open-Meteo (free, no API key).
# These variables are kept as optional/unused comments for reference only.
# OWM_API_KEY=
# AMBEE_API_KEY=

# Path to the SQLite database file (defaults to /data/cranial.db inside the container)
DATABASE_PATH=/data/cranial.db
